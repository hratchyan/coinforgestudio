{
  "name": "coinforge-studio",
  "productName": "CoinForge Studio",
  "version": "1.4.0",
  "description": "Coin & challenge-coin designer for laser engraving — rings, symbols, smart photo import, and DPI-exact export.",
  "author": {
    "name": "Hratch Simonyan",
    "email": "contact@hratchyan.com"
  },
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "serve": "node tools/serve.js",
    "docs": "node tools/embed-docs.js",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "31.7.6",
    "electron-builder": "24.13.3",
    "ffmpeg-static": "^5.3.0",
    "firebase-tools": "^15.22.4",
    "puppeteer-core": "^25.3.0"
  },
  "build": {
    "appId": "com.hratchsimonyan.coinforge",
    "productName": "CoinForge Studio",
    "copyright": "© 2026 Hratch Simonyan",
    "compression": "normal",
    "files": [
      "electron/**/*",
      "app/**/*",
      "docs/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "CoinForgeStudio-Portable.exe"
    },
    "nsis": {
      "artifactName": "CoinForgeStudio-Setup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "CoinForge Studio",
      "differentialPackage": false
    }
  }
}
